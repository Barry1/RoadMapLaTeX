% myroadmap.sty - RoadMapLaTeX v6.2 (2026)
% Opportunities / Customer X Fix + stabilere Zeilenverwaltung

\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{myroadmap}[2026/05/21 v6.2 – Robust Opportunities Fix]

\RequirePackage[l2tabu, orthodox]{nag}
\RequirePackage{calc}
\RequirePackage{mathabx}
\RequirePackage{fontspec}
\RequirePackage{booktabs}
\RequirePackage{pgfgantt}[2018/01/10]
\RequirePackage{xcolor}
\RequirePackage{pgfkeys}
\RequirePackage{ifthen}

\input{roadmapcolors.def}

% =============================================
% Längen
% =============================================
\newlength{\myroadmapwidth}
\newlength{\myroadmappagediff}

% =============================================
% pgfkeys
% =============================================
\pgfkeys{/myroadmap/.cd,
	font/.initial=Arial,
	OpportunityColor/.initial=cyan,
	ProductColor/.initial=blue,
	TechnologyColor/.initial=red!50!yellow,
	roadmapwidth/.code={\setlength{\myroadmapwidth}{#1}},
	aedate/.initial={\today},
	builddate/.initial={\today},
	proddate/.initial={\today},
	techdate/.initial={\today},
	state/.initial=release,
}

\newcommand{\setroadmapoptions}[1]{\pgfkeys{/myroadmap/.cd,#1}}

% Font Fallback
\AtBeginDocument{%
	\IfFontExistsTF{\pgfkeysvalueof{/myroadmap/font}}{%
		\setmainfont{\pgfkeysvalueof{/myroadmap/font}}%
	}{%
		\PackageWarning{myroadmap}{Font „\pgfkeysvalueof{/myroadmap/font}“ not found.}%
	}%
}

% =============================================
% Layer
% =============================================
\newcommand{\roadmaplayer}[1]{%
	\ganttnewline%
	\ganttgroup[inline=false]{#1}{\pgfkeysvalueof{/pgfgantt/roadmap start}}{\pgfkeysvalueof{/pgfgantt/roadmap end}}%
	\ganttnewline%
}

% =============================================
% Harvey Balls
% =============================================
\@gtt@keydef{harvey percent}{50}
\@gtt@keydef{harvey radius}{1.5mm}
\@gtt@keydef{harvey color}{black}

\def\drawharveyball#1#2{%
	\pgfmathsetmacro\harveyangle{90 - 360* (#2/100)}% chktex 8
	\fill[white] (#1) -- ++ (\harveyangle:\ganttvalueof{harvey radius})% chktex 8
	arc [radius=\ganttvalueof{harvey radius}, start angle=\harveyangle, end angle=-270] -- cycle;% chktex 8
	\fill[\ganttvalueof{harvey color}] (#1) -- ++ (90:\ganttvalueof{harvey radius})% chktex 8
	arc [radius=\ganttvalueof{harvey radius}, start angle=90, end angle=\harveyangle] -- cycle;% chktex 8
	\draw(#1) circle [radius=\ganttvalueof{harvey radius}];
}

\newganttchartelement*{harveyanchor}{harveyanchor/.style={shape=ganttbar}}

% =============================================
% Placement Commands
% =============================================
\newcommand*{\placeTech}[4]{%
	\ganttbar[name=#1, bar/.append style={fill=\pgfkeysvalueof{/myroadmap/TechnologyColor}, rounded corners=1mm}]{#2}{#3}{#4}%
}

\newcommand*{\placePostTech}[4]{%
	\ganttbar[name=#1, inline, bar label font=\footnotesize,
		bar/.append style={fill=\pgfkeysvalueof{/myroadmap/TechnologyColor}!40, rounded corners=1mm}]{#2}{#3}{#4}%
}

\newcommand*{\placeProdDevSer}[4]{%
	\ganttbar[name=#1, inline, bar label font=\footnotesize,
		bar/.append style={fill=\pgfkeysvalueof{/myroadmap/ProductColor}!40, rounded corners=1mm}]{#2}{#3}{#4}%
}

\newcommand*{\placeProd}[4]{%
	\ganttbar[name=#1, bar/.append style={fill=\pgfkeysvalueof{/myroadmap/ProductColor}, rounded corners=1mm}]{#2}{#3}{#4}%
}

% ==================== ROBUSTER Opportunities Fix ====================
\newcommand*{\placeCust}[4]{%
	\ganttbar[%
		name=#1,
		inline=true,
		bar height=0.85,
		bar top shift=0.08,
		bar/.append style={draw=none},
		bar inline label node/.append style={%
				inner sep=3pt,
				text=white,
				fill=\pgfkeysvalueof{/myroadmap/OpportunityColor},
				rounded corners=3mm,
				font=\small\bfseries
			}%
	]{#2}{#3-#4}{#3-#4}%
}

\newcommand*{\placeBackupCust}[4]{%
	\ganttbar[%
		name=#1,
		inline=true,
		bar height=0.85,
		bar top shift=0.08,
		bar/.append style={draw=none},
		bar inline label node/.append style={%
				inner sep=3pt,
				text=white,
				fill=\pgfkeysvalueof{/myroadmap/OpportunityColor}!40,
				rounded corners=3mm,
				font=\small\bfseries
			}%
	]{#2}{#3-#4}{#3-#4}%
}

% =============================================
% Harvey Links
% =============================================
\newganttlinktype{harveySellProd}{%
	\ganttsetendanchor{on bottom=0.5}%
	\coordinate(harveycenter) at (\xRight, \yUpper);%
	\ganttset{harvey color=\pgfkeysvalueof{/myroadmap/OpportunityColor}}%
	\drawharveyball{harveycenter}{\ganttvalueof{harvey percent}}%
	\draw[thick, ->,myMediumGray] (\xRight, \yUpper+\ganttvalueof{harvey radius}) -- (\xRight, \yLower);% chktex 8
}

\newganttlinktype{harveyImplementTech}{%
	\coordinate(harveycenter) at (\xLeft, \yLower);%
	\draw[thick, ->,myMediumGray] (\xLeft, \yUpper) -- (\xLeft, \yLower-\ganttvalueof{harvey radius});% chktex 8
	\ganttset{harvey color=\pgfkeysvalueof{/myroadmap/TechnologyColor}}%
	\drawharveyball{harveycenter}{\ganttvalueof{harvey percent}}%
}

% Legend
\ifdefined\standalone\else
	\input{legendtypesetting.def}

\fi

% =============================================
% bastiroadmap Umgebung (mehr vertikaler Platz)
% =============================================
\newenvironment{bastiroadmap}[4][]{% #1=options, #2=title, #3=start, #4=end
\@gtt@keydef{roadmap start}{#3}%
\@gtt@keydef{roadmap end}{#4}%
\setroadmapoptions{#1}%
\setlength{\myroadmappagediff}{\linewidth-\myroadmapwidth}%

\ifdefined\standalone%
\begin{ganttchart}[% chktex 15 - cant understand No match found for `ganttchart'
vgrid={*5{draw=none},*1{red,dashed},*6{draw=none}},
time slot format=isodate-yearmonth,
time slot unit=month,
x unit=0.22cm,
y unit chart=0.72cm,      % mehr Platz
y unit title=0.72cm,
title height=1,
bar height=.75,
bar top shift=.12,
newline shortcut=true,
include title in canvas=false
]{#3}{#4}
\else
\begin{center}#2\end{center}
\begin{ganttchart}[
	vgrid={*5{draw=none},*1{red,dashed},*6{draw=none}},
	time slot format=isodate-yearmonth,
	time slot unit=month,
	x unit=0.22cm,
	y unit chart=0.72cm,
	y unit title=0.72cm,
	title height=1,
	bar height=.75,
	bar top shift=.12,
	newline shortcut=true,
	expand chart=\myroadmapwidth,
	include title in canvas=false
	]{#3}{#4}
	\fi
	}{%
\end{ganttchart}
\ifdefined\standalone\else\par\myroadmaplegend\fi
}

\endinput
